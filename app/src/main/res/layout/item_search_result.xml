<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/iconTextView"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_item_icon_box"
            android:gravity="center"
            android:textColor="@color/secondary_text"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="M" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/titleTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/surface_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="Morning Brew" />

                <View
                    android:id="@+id/verifiedDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_brand_dot" />
            </LinearLayout>

            <TextView
                android:id="@+id/subtitleTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/surface_text_secondary"
                android:textSize="12sp"
                tools:text="Become smarter in just 5 minutes..." />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/categoryTagTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_blue_soft"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:textColor="@color/brand_primary"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    tools:text="BUSINESS" />

                <TextView
                    android:id="@+id/frequencyTagTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_filter_chip_inactive"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:textColor="@color/secondary_text"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    tools:text="DAILY" />
            </LinearLayout>
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/viewButton"
            android:layout_width="74dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_view_button"
            android:gravity="center"
            android:includeFontPadding="false"
            android:lines="1"
            android:maxLines="1"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="@string/search_view"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
